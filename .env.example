# Environment Configuration for Diabetes Prediction System
# Copy this file to .env and update with your values

# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-this-in-production
DEBUG=False

# Database Configuration
DATABASE_URL=sqlite:///database/diabetes.db
# For PostgreSQL: postgresql://username:password@localhost:5432/diabetes_db

# Redis Configuration (for background tasks)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Email Configuration
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Security Configuration
DB_ENCRYPTION_PASSWORD=your-encryption-password-change-this

# Healthcare Configuration
POSTGRES_SSL_MODE=require

# File Paths (use relative paths in production deployments)
PROJECT_ROOT=.
ML_MODEL_PATH=ml_model/saved_models/gradient_boosting.pkl
SCALER_PATH=ml_model/saved_models/scaler.pkl

# Payment Gateway (Chapa)
# Dashboard: https://dashboard.chapa.co/
# Test keys (sandbox): CHASECK_TEST-xxxx / CHAPUBK_TEST-xxxx
# Live keys (production): CHASECK-xxxx / CHAPUBK-xxxx
CHAPA_SECRET_KEY=CHASECK_TEST-your-secret-key
CHAPA_PUBLIC_KEY=CHAPUBK_TEST-your-public-key
CHAPA_WEBHOOK_SECRET=your-webhook-secret
CHAPA_BASE_URL=https://api.chapa.co/v1
CHAPA_CALLBACK_URL=https://yourdomain.com/api/payments/chapa/verify
CHAPA_RETURN_URL=https://yourdomain.com/templates/payment/payment_success.html

# Monitoring
GRAFANA_PASSWORD=admin123

# Development Settings
TESTING=False
WTF_CSRF_ENABLED=True
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_SAMESITE=Lax
ALLOW_ADMIN_SIGNUP=False
# Only this email may log in as admin when set (optional hard lock).
ADMIN_EMAIL=admin@yourdomain.com

# First-time admin (empty database): run once from project root:
#   python tools/bootstrap_admin.py
# Then remove or blank these from production .env.
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_BOOTSTRAP_USERNAME=
